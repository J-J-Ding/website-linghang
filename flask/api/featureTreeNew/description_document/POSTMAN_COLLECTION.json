            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"seedComponentId\": \"C-F023-PRTC 组件\",\n  \"scope\": \"L1\",\n  \"maxDepth\": 2,\n  \"forceRefresh\": false,\n  \"operatorPerson\": \"测试用户\"\n}"
        },
        "url": {
          "raw": "{{base_url}}{{api_path}}/API_Knowledge_component_graph_get",
          "host": ["{{base_url}}"],
          "path": ["{{api_path}}", "API_Knowledge_component_graph_get"]
        },
        "description": "获取组件知识图谱\n\n请求参数：\n- seedComponentId: 种子组件 ID 或名称（必填）\n- scope: 范围 L0/L1/L2/WASON/OSP（必填）\n- maxDepth: 最大展开深度，默认 2（可选）\n- forceRefresh: 是否强制刷新，默认 false（可选）\n- operatorPerson: 操作人（可选）"
      },
      "response": []
    },
